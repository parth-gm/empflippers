# Redis for Sidekiq
REDIS_URL=redis://localhost:6379/0

# HubSpot — Private App access token
HUBSPOT_API_KEY=dummy-replace-with-hubspot-private-app-token

# PostgreSQL
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/empflippers_development
# On host with Docker publishing 5432: 127.0.0.1. Inside compose stack: postgres.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Google Sheets — use ONE of: single-line JSON OR base64 of the JSON file (Docker-friendly)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SHEETS_SYNC_ENABLED=false
GOOGLE_SHEETS_NEW_SPREADSHEET_TITLE=Empire Flippers Listings
# Tab to clear and rewrite each sync (if blank, GOOGLE_SHEETS_SHEET_NAME_PREFIX or "Listings" is used)
GOOGLE_SHEETS_TAB_NAME=Listings
GOOGLE_SHEETS_SHEET_NAME_PREFIX=Listings
# Spreadsheet ID or full URL — required for overwrite mode (share with client_email as Editor)
GOOGLE_SHEETS_SPREADSHEET_ID=https://docs.google.com/spreadsheets/d/REPLACE_WITH_YOUR_SHEET_ID/edit

# Optional HubSpot deal routing (pipeline / stage IDs from HubSpot)
# HUBSPOT_DEAL_PIPELINE_ID=
# HUBSPOT_DEAL_STAGE_ID=
